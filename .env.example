# Web
WEB_PORT=5000
WEB_DEBUG=false

# AI text
AI_TEXT_API_KEY=replace-with-text-key
AI_TEXT_API_BASE=https://api.kk666.best
AI_TEXT_ENDPOINT_TEMPLATE=/v1/responses
AI_TEXT_PROTOCOL=openai_responses
AI_TEXT_MODEL=gpt-5.5

# AI image
AI_IMAGE_API_KEY=replace-with-image-key
AI_IMAGE_API_BASE=https://api.kk666.best
AI_IMAGE_ENDPOINT_TEMPLATE=/v1/images/generations
AI_IMAGE_PROTOCOL=openai_images
AI_IMAGE_MODEL=gpt-image-2

# Amazon SP-API
# Web 工作台会优先使用 accounts.json 中的默认账号。
# 如果要跑 stage2_pipeline.py / main.py 这类 CLI 链路，也需要补齐下面这些值。
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE=ATVPDKIKX0DER

# Directories
INPUT_DIR=
OUTPUT_DIR=
LOGS_DIR=

# Media / image publishing
OUTPUT_IMAGE_PUBLIC_BASE=
MEDIA_STORE_ENABLED=false
MEDIA_STORE_PROVIDER=
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_PREFIX=amazon28
MEDIA_S3_SUBMIT_SCHEME=s3
MEDIA_S3_PREVIEW_BASE=

# Runtime
DEFAULT_LANG=zh
BATCH_LIMIT=500
AI_CONCURRENCY=3
IMAGE_CONCURRENCY=2
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=3

# 网络代理（在公司网/有防火墙时填，没限制就留空）
# 例：HTTP_PROXY=http://proxy.公司域名:8080
# 同时建议把 NO_PROXY 设成本机回环，避免 Web 自启回路被代理
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
